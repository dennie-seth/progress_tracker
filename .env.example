# Telegram bot token from @BotFather
BOT_TOKEN=

# PostgreSQL async DSN. For docker compose this defaults to the db service.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/progress_tracker

# Directory where uploaded videos are stored (local storage backend).
MEDIA_DIR=/data/media

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Custom Telegram Bot API server (optional, milestone 2.5) ---
# Point at an existing self-hosted telegram-bot-api instance for 2 GB file
# limits. Empty = use cloud api.telegram.org (20 MB upload / 50 MB download).
# If you switch a bot that was previously registered with the cloud API, run
# once BEFORE first connection:
#     curl "https://api.telegram.org/bot<BOT_TOKEN>/logOut"
BOT_API_URL=

# SOCKS5 proxy for Bot API traffic (auth form: user:pass).
# Format: socks5://user:pass@host:port — leave empty for a direct connection.
SOCKS_PROXY_URL=
